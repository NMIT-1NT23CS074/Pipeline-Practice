pipeline{
    agent any
    stages{
        stage("uptime"){
            steps{
                sh '''
                uptime
                '''
            }
        }
        stage("Ram-used"){
            steps{
                sh '''
                free -h
                '''
            }
        }
         stage("Disk-used"){
            steps{
                sh '''
                df -h
                '''
            }
        }   

        stage("poll scm"){
            steps{
                echo "polling scm for every minutes,hrs,days,montths,weekdays"
            }
        }
    }
}